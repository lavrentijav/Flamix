{
  "id": "1d142a87-2353-47d0-9883-fed9037d0a9b",
  "name": "Windows Firewall Plugin (Netsh)",
  "version": "0.1.0",
  "author": "Flamix Team",
  "platforms": ["windows"],
  "entry_point": "plugin.py",
  "capabilities": ["manage_rules", "view_logs"],
  "permissions": [
    "run_shell_commands:netsh",
    "run_shell_commands:powershell"
  ],
  "dependencies": {},
  "signature": "",
  "checksum": "",
  "api_version": "1.0",
  "rule_schema": {
    "fields": [
      {
        "name": "name",
        "type": "text",
        "label": "Rule Name",
        "required": true,
        "default": "Flamix Rule"
      },
      {
        "name": "port",
        "type": "number",
        "label": "Port",
        "required": false,
        "min": 1,
        "max": 65535,
        "default": null
      },
      {
        "name": "protocol",
        "type": "select",
        "label": "Protocol",
        "required": true,
        "options": [
          {"value": "tcp", "label": "TCP"},
          {"value": "udp", "label": "UDP"},
          {"value": "icmp", "label": "ICMP"},
          {"value": "any", "label": "Any"}
        ],
        "default": "tcp"
      },
      {
        "name": "action",
        "type": "radio",
        "label": "Action",
        "required": true,
        "options": [
          {"value": "allow", "label": "Allow"},
          {"value": "block", "label": "Block"}
        ],
        "default": "allow"
      },
      {
        "name": "direction",
        "type": "radio",
        "label": "Direction",
        "required": true,
        "options": [
          {"value": "in", "label": "Inbound"},
          {"value": "out", "label": "Outbound"}
        ],
        "default": "in"
      },
      {
        "name": "profile",
        "type": "select",
        "label": "Profile",
        "required": true,
        "options": [
          {"value": "any", "label": "Any Profile"},
          {"value": "domain", "label": "Domain"},
          {"value": "private", "label": "Private"},
          {"value": "public", "label": "Public"}
        ],
        "default": "any"
      }
    ]
  },
  "firewall_support": [
    {
      "name": "windows_firewall",
      "versions": {
        "min": "6.0.0",
        "max": null,
        "exact": []
      },
      "detect": {
        "type": "command",
        "value": "netsh advfirewall show allprofiles state"
      },
      "regex": [
        "State\\s+(ON|OFF)",
        "Windows Firewall is (enabled|disabled)"
      ],
      "requires_root": true,
      "priority": 100
    }
  ]
}

